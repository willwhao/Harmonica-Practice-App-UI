# Enabling this variable switches the browser app from local accounts to cloud accounts.
VITE_API_URL=http://localhost:8787

# Release and feature flags. Channels: development, preview, production.
VITE_APP_VERSION=0.0.1
VITE_RELEASE_CHANNEL=development
VITE_FEATURE_AUDIO_UPLOAD=true
VITE_FEATURE_PRACTICE_RECORDING=true
VITE_FEATURE_CLOUD_SYNC=true
VITE_FEATURE_LEARNING_CENTER=true
VITE_FEATURE_CHROMATIC_CHARTS=true
VITE_FEATURE_LOCAL_MONITORING=true
VITE_FEATURE_OPERATIONS_PANEL=true

# Server-only values. Use a unique random secret with at least 32 characters.
JWT_SECRET=replace-with-a-long-random-production-secret
DATABASE_PATH=harmonica.sqlite
APP_ORIGIN=http://localhost:5173
PORT=8787

# Required in production for password-reset email delivery.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Harmonica Practice <no-reply@example.com>
