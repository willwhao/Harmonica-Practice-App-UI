{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build --configLoader runner",
    "dev": "vite --configLoader runner",
    "dev:api": "tsx server/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src server e2e vite.config.ts vitest.config.ts playwright.config.ts",
    "quality": "npm run typecheck && npm run lint && npm run test && npm run test:components && npm run test:e2e && npm run build && npm run check:budget",
    "test": "npm run test:pitch && npm run test:auth && npm run test:learning && npm run test:practice && npm run test:charts && npm run test:privacy && npm run test:compat && npm run test:quality && npm run test:api",
    "test:pitch": "node --test src/app/audio/pitchDetection.test.ts src/app/audio/pitchRegression.test.ts src/app/audio/practiceAudioAssets.test.ts src/app/audio/audioTranscription.test.ts src/app/audio/transcriptionChart.test.ts",
    "test:auth": "node --test src/app/auth/authStore.test.ts",
    "test:learning": "node --test src/app/learning/learningStats.test.ts",
    "test:practice": "node --test src/app/practice/practiceWindow.test.ts src/app/practice/practiceInsights.test.ts src/app/practice/scoreLayout.test.ts src/app/practice/recordingSegments.test.ts",
    "test:charts": "node --test src/app/data/practiceCharts.test.ts",
    "test:privacy": "node --test src/app/privacy/privacyChecklist.test.ts",
    "test:compat": "node --test src/app/compat/compatibilityChecklist.test.ts",
    "test:quality": "node --test src/app/quality/performanceBudget.test.ts src/app/quality/monitoring.test.ts",
    "test:api": "tsx --test server/app.test.ts",
    "test:components": "vitest run --configLoader runner",
    "test:e2e": "playwright test",
    "check:budget": "node scripts/check-performance-budget.mjs",
    "check:release": "node scripts/check-release-readiness.mjs"
  },
